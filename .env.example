# Host ports. Defaults avoid common local ports already used by this machine.
FRONTEND_HOST_PORT=18011
BACKEND_HOST_PORT=18010

# Database settings used by the MySQL container and Spring Boot.
MYSQL_DATABASE=yxtyg_db
MYSQL_ROOT_PASSWORD=123456
MYSQL_USER=root

# Runtime timezone.
TZ=Asia/Shanghai

# External AI services. Leave these as external endpoints for local Docker dev.
AI_OLLAMA_URL=http://gugang.i234.me:11868
AI_OLLAMA_MODEL=qwen3:8b
